{
  "name": "devtools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "cd tests && npx vitest run",
    "test:e2e": "cd tests && npx playwright test",
    "test:visual": "cd tests && npx playwright test --grep visual",
    "test:all": "cd tests && npx vitest run && npx playwright test",
    "test:report": "node tests/utils/reporter.js"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "*",
    "clsx": "*",
    "codemirror": "^6.0.2",
    "lucide-vue-next": "*",
    "radix-vue": "*",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "*",
    "vue": "^3.4.0",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.2.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0",
    "vite": "^6.1.0",
    "vue-tsc": "^2.0.0"
  }
